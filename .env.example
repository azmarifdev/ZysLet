NODE_ENV=production
PORT=5000

NEXT_PUBLIC_BASE_URL=https://server.zyslet.com
NEXT_PUBLIC_API_BASE_URL=https://server.zyslet.com
LOCAL_FILE_URL=https://server.zyslet.com/

DB_NAME=zyslet_prod
DB_USERNAME=<db-user>
DB_PASSWORD=<db-password>
DATABASE_URL=mongodb+srv://<db-user>:<db-password>@cluster0.nxs06e1.mongodb.net/zyslet_prod?retryWrites=true&w=majority&appName=Cluster0

BCRYPT_SALT_ROUNDS=10
JWT_SECRET_TOKEN=change_me_super_secret
JWT_EXPIRE_IN=2d
JWT_REFRESH_TOKEN=change_me_refresh_secret
JWT_REFRESH_EXPIRE_IN=30d

CLOUDINARY_CLOUD_NAME=zyslet
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

NEXT_PUBLIC_GTM_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PIXEL_ID=
NEXT_PUBLIC_META_PIXEL_ID=

NEXT_PUBLIC_WHATSAPP_NUMBER=8801810011145
NEXT_PUBLIC_WHATSAPP_CONFIRM_MESSAGE=Hi ZysLet, I placed an order. Order ID: {orderId}. Please confirm my order.
NEXT_PUBLIC_FREE_SHIPPING_THRESHOLD=0
NEXT_PUBLIC_MINIMUM_ORDER_AMOUNT=0
