NODE_ENV=production
PORT=5000

API_URL=https://server.zyslet.com
CLIENT_URL=https://zyslet.com
ADMIN_URL=https://admin.zyslet.com
LOCAL_FILE_URL=https://server.zyslet.com/
CORS_ORIGIN=https://admin.zyslet.com,https://zyslet.com,https://server.zyslet.com

DATABASE_URL=mongodb+srv://<db-user>:<db-password>@cluster0.nxs06e1.mongodb.net/zyslet_prod?retryWrites=true&w=majority&appName=Cluster0

BCRYPT_SALT_ROUNDS=10
JWT_SECRET_TOKEN=change_me_super_secret
JWT_EXPIRE_IN=2d
JWT_REFRESH_TOKEN=change_me_refresh_secret
JWT_REFRESH_EXPIRE_IN=30d

CLOUDINARY_CLOUD_NAME=zyslet
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PIXEL_ID=

COOKIE_DOMAIN=.zyslet.com

# Server performance / security tuning
REQUEST_BODY_LIMIT=10mb
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=600
